PG_DATABASE_URL="postgresql://..."
AUDIT_DATABASE_URL=""
OPENAI_API_KEY="sk-..."

MODERATION_MODEL="omni-moderation-latest"
MODERATION_BATCH_SIZE=100
MODERATION_CONCURRENCY=2
MODERATION_SLEEP_MS=250
MAX_IMAGES_PER_POST=4
MAX_IMAGE_BYTES=20971520
MAX_CONSECUTIVE_INFRA_ERRORS=10
OPENAI_MODERATION_RPM=200
OPENAI_MODERATION_TPM=4500
OPENAI_MODERATION_RPD=9000
OPENAI_MODERATION_TPD=900000
OPENAI_TEXT_BATCH_SIZE=40
OPENAI_TEXT_BATCH_TOKEN_LIMIT=4000
TRUSTED_GOOD_POST_THRESHOLD=15
NEW_ACCOUNT_YEARS=2

OUTPUT_FILE="./moderation-report.json"
CHECKPOINT_FILE="./moderation-checkpoint.json"
ERROR_LOG_FILE="./moderation-errors.jsonl"
ERROR_REPORT_FILE="./moderation-error-report.json"

DRY_RUN=true
INCLUDE_RAW_OPENAI=false
